DATABASE_URL=postgres://yorishiro:yorishiro@localhost:5432/yorishiro
YSR_BIND=0.0.0.0:8080
YSR_CORS_ORIGINS=

# Embeddings provider: openai (OpenAI-compatible API) | local (local ONNX model)
YSR_EMBEDDING_PROVIDER=openai
# entities.embedding is fixed at vector(768), so any value other than 768 is a startup error
YSR_EMBEDDING_DIMENSIONS=768

# --- When YSR_EMBEDDING_PROVIDER=openai (e.g. Ollama, LM Studio, OpenAI) ---
YSR_EMBEDDING_BASE_URL=http://localhost:11434/v1
YSR_EMBEDDING_MODEL=nomic-embed-text
YSR_EMBEDDING_API_KEY=
# Whether to include a dimensions parameter in the request body (false for unsupported servers)
YSR_EMBEDDING_SEND_DIMENSIONS_PARAM=true

# --- When YSR_EMBEDDING_PROVIDER=local (768-dimensional BERT-family ONNX export) ---
# e.g. onnx/model_quantized.onnx and tokenizer.json from
# https://huggingface.co/Xenova/all-mpnet-base-v2
#YSR_ONNX_MODEL_PATH=models/model.onnx
#YSR_ONNX_TOKENIZER_PATH=models/tokenizer.json
#YSR_ONNX_MAX_SEQUENCE_LENGTH=512

RUST_LOG=info
# Log output target: stdout (default) | single | daily | syslog
YSR_LOG_TARGET=stdout
# When YSR_LOG_TARGET=single or daily
#YSR_LOG_DIR=.
# When YSR_LOG_TARGET=syslog
#YSR_SYSLOG_SOCKET=/dev/log
