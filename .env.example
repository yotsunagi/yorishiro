# Every setting below can also go in a config.yml file instead (see config.example.yml) --
# environment variables win when both are set. A missing config.yml is not an error.
DATABASE_URL=postgres://yorishiro:yorishiro@localhost:5432/yorishiro
YSR_BIND=0.0.0.0:8080
YSR_CORS_ORIGINS=

# Deployment-wide cap on the number of tenants `admin create-tenant` may create. Defaults to 1
# (single-tenant) if unset -- set to 0 for unlimited, or to a higher number to allow that many
# tenants. `POST /auth/signup` never creates a tenant (it only redeems an invite into an
# existing one), so it is unaffected by this cap. Also gates the first-run setup wizard
# (GET/POST /setup) -- enabled only while the cap resolves to an actual limit (i.e. not 0).
#YORISHIRO_MAX_TENANTS=1

# Directory the setup/login web UI's static files are served from at "/". Defaults to `web`
# (the directory shipped alongside the binary/Docker image) if unset.
#YSR_WEB_DIR=web

# Per-client-IP rate limit on /auth/signup, /auth/login, and /setup -- the endpoints reachable
# without a bearer token. Defaults shown below.
#YSR_AUTH_RATE_LIMIT_MAX=10
#YSR_AUTH_RATE_LIMIT_WINDOW_SECS=60

# Embeddings provider: local (local ONNX model, default) | openai (OpenAI-compatible API)
#YSR_EMBEDDING_PROVIDER=local
# entities.embedding is fixed at vector(768), so any value other than 768 is a startup error
YSR_EMBEDDING_DIMENSIONS=768

# --- When YSR_EMBEDDING_PROVIDER=local (768-dimensional BERT-family ONNX export, the default) ---
# Place onnx/model_quantized.onnx and tokenizer.json from
# https://huggingface.co/Xenova/all-mpnet-base-v2 at the paths below (already the defaults) and
# no embedding-related variable needs to be set at all.
#YSR_ONNX_MODEL_PATH=models/model.onnx
#YSR_ONNX_TOKENIZER_PATH=models/tokenizer.json
#YSR_ONNX_MAX_SEQUENCE_LENGTH=512

# --- When YSR_EMBEDDING_PROVIDER=openai (e.g. Ollama, LM Studio, OpenAI) ---
#YSR_EMBEDDING_BASE_URL=http://localhost:11434/v1
#YSR_EMBEDDING_MODEL=nomic-embed-text
#YSR_EMBEDDING_API_KEY=
# Whether to include a dimensions parameter in the request body (false for unsupported servers)
#YSR_EMBEDDING_SEND_DIMENSIONS_PARAM=true

RUST_LOG=info
# Log output target: stdout (default) | single | daily | syslog
YSR_LOG_TARGET=stdout
# When YSR_LOG_TARGET=single or daily
#YSR_LOG_DIR=.
# When YSR_LOG_TARGET=syslog
#YSR_SYSLOG_SOCKET=/dev/log
