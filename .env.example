DATABASE_URL=postgres://yorishiro:yorishiro@localhost:5432/yorishiro
YSR_BIND=0.0.0.0:8080
YSR_CORS_ORIGINS=

# OpenAI互換embeddings API（例: Ollama, LM Studio, OpenAI）
YSR_EMBEDDING_BASE_URL=http://localhost:11434/v1
YSR_EMBEDDING_MODEL=nomic-embed-text
YSR_EMBEDDING_API_KEY=
# entities.embeddingはvector(768)固定のため768以外は起動時エラー
YSR_EMBEDDING_DIMENSIONS=768
# リクエストボディにdimensionsパラメータを含めるか（非対応サーバーではfalse）
YSR_EMBEDDING_SEND_DIMENSIONS_PARAM=true

RUST_LOG=info
